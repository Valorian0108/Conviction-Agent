# Conviction Agent — Environment Variables
# Copy this file to .env and fill in your keys

# Required: Qwen AI (get from Alibaba Cloud or hackathon credits)
QWEN_API_KEY=your-qwen-api-key-here

# Required: Bitget API (for live price data and sim execution)
BITGET_API_KEY=your-bitget-api-key-here
BITGET_API_SECRET=your-bitget-api-secret-here
BITGET_PASSPHRASE=your-bitget-passphrase-here

# Required: GitHub (authenticated = 5000 req/hr vs 60 req/hr unauthenticated)
GITHUB_TOKEN=your-github-token-here

# Optional: Telegram alerts (create a bot at t.me/BotFather)
TELEGRAM_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Optional: Flask session (auto-generated if not set)
SESSION_SECRET=any-random-string-here
